begin function {}
	array_var aItems = RefMapArrayGetKeys "*_PWBVRV"

	if eval (Ar_Size aItems) <= 0
		return
	endif

	foreach array_var aEntry <- aItems
		ref rItem = aEntry["value"]
		short iItemValue = RefMapArrayGetFloat "*_PWBVRV" rItem
		
		SetBaseItemValue rItem iItemValue
	loop

	let aItems := Ar_Null
	RefMapDestroy "*_PWBVRV"
end